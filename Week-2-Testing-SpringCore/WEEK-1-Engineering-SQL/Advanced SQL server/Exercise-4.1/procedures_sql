-- ====================================================================
-- Exercise 9 & 11: Transactions and Structured Error Handling
-- Goal: Protect data integrity using TRY...CATCH and transaction tokens
-- ====================================================================
CREATE PROCEDURE sp_UpdateSalarySafe
    @EmployeeID INT,
    @NewSalary DECIMAL(10,2)
AS
BEGIN
    SET NOCOUNT ON;
    
    BEGIN TRY
        BEGIN TRANSACTION;
        
        -- Business Logic validation rule: Check for negative values
        IF @NewSalary < 0
        BEGIN
            THROW 51000, 'Salary cannot be negative. Operation aborted.', 1;
        END

        UPDATE Employees
        SET Salary = @NewSalary
        WHERE EmployeeID = @EmployeeID;
        
        COMMIT TRANSACTION;
    END TRY
    BEGIN CATCH
        -- Rollback state safely if any crash occurred
        IF @@TRANCOUNT > 0 ROLLBACK TRANSACTION;
        
        -- Re-throw error back to application
        DECLARE @ErrorMessage NVARCHAR(4000) = ERROR_MESSAGE();
        RAISERROR(@ErrorMessage, 16, 1);
    END CATCH
END;
GO


-- ====================================================================
-- Exercise 10: Use Dynamic SQL inside Stored Procedures
-- Goal: Build highly flexible query interfaces for front-end searches
-- ====================================================================
CREATE PROCEDURE sp_FindEmployeesDynamic
    @FilterColumn VARCHAR(50),
    @FilterValue VARCHAR(100)
AS
BEGIN
    SET NOCOUNT ON;
    DECLARE @DynamicQuery NVARCHAR(MAX);
    
    -- Safeguard against SQL Injection vulnerabilities by checking valid columns
    IF @FilterColumn NOT IN ('FirstName', 'LastName', 'Region')
    BEGIN
        RAISERROR('Invalid search target parameter.', 16, 1);
        RETURN;
    END

    -- Build and map query parameters cleanly
    SET @DynamicQuery = N'SELECT * FROM Employees WHERE ' + QUOTENAME(@FilterColumn) + N' = @ParamValue';
    
    EXEC sp_executesql @DynamicQuery, N'@ParamValue VARCHAR(100)', @ParamValue = @FilterValue;
END;
GO
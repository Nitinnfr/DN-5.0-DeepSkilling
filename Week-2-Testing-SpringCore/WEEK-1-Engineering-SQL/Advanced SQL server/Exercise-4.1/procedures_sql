-- ====================================================================
-- Exercise 1 & 2: Create and Modify a Stored Procedure
-- Goal: Retrieve employee details alongside department and salary
-- ====================================================================
CREATE PROCEDURE sp_GetEmployeesByDepartment
    @DepartmentID INT
AS
BEGIN
    SET NOCOUNT ON;
    SELECT EmployeeID, FirstName, LastName, Salary, DepartmentID 
    FROM Employees
    WHERE DepartmentID = @DepartmentID;
END;
GO



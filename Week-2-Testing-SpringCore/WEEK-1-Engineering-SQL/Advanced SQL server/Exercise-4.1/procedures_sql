-- ====================================================================
-- Exercise 5 & 6: Output Parameters and Aggregations
-- Goal: Return aggregate headcount and metrics via output fields
-- ====================================================================
CREATE PROCEDURE sp_GetDepartmentMetrics
    @DepartmentID INT,
    @EmpCount INT OUTPUT,
    @TotalSalary DECIMAL(10,2) OUTPUT
AS
BEGIN
    SET NOCOUNT ON;
    
    -- Count total employees (Exercise 5)
    SELECT @EmpCount = COUNT(*) 
    FROM Employees 
    WHERE DepartmentID = @DepartmentID;
    
    -- Sum aggregate payroll (Exercise 6)
    SELECT @TotalSalary = ISNULL(SUM(Salary), 0) 
    FROM Employees 
    WHERE DepartmentID = @DepartmentID;
END;
GO


-- ====================================================================
-- Exercise 8: Stored Procedure with Conditional Logic
-- Goal: Apply targeted bonuses conditionally inside data logic blocks
-- ====================================================================
CREATE PROCEDURE sp_GiveBonus
    @DepartmentID INT,
    @BonusAmount DECIMAL(10,2)
AS
BEGIN
    SET NOCOUNT ON;
    
    -- Simple conditional check example
    IF EXISTS (SELECT 1 FROM Employees WHERE DepartmentID = @DepartmentID)
    BEGIN
        UPDATE Employees
        SET Salary = Salary + @BonusAmount
        WHERE DepartmentID = @DepartmentID;
    END
END;
GO

